{
  "name": "@imminently/log-whisperer",
  "version": "0.1.5",
  "description": "AI-powered daily summaries of operational issues in cloud runtimes",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "log-whisperer": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "deploy": "npm run publish:patch",
    "publish:patch": "npm run version:patch && npm run build && npm publish",
    "publish:minor": "npm run version:minor && npm run build && npm publish",
    "publish:major": "npm run version:major && npm run build && npm publish"
  },
  "keywords": [
    "logging",
    "monitoring",
    "azure",
    "application-insights",
    "ai",
    "summarization",
    "slack"
  ],
  "author": "Joel Nation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/imminently/log-whisperer.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@azure/identity": "^4.13.0",
    "@azure/monitor-query-logs": "^1.0.0",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.0",
    "openai": "^6.17.0",
    "yaml": "^2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
