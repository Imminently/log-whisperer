# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Azure Configuration
AZURE_WORKSPACE_ID=your-workspace-id-here
AZURE_TENANT_ID=optional-tenant-id
AZURE_SUBSCRIPTION_ID=optional-subscription-id
AZURE_CLIENT_ID=optional-client-id-for-service-principal
AZURE_CLIENT_SECRET=optional-client-secret-for-service-principal

# Slack Configuration
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Optional: Metadata for notifications
ENVIRONMENT=production
SERVICE_NAME=my-service
